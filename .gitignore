# =====================================
# CriticCode AI - .gitignore
# =====================================

# Environment Variables (Never commit these!)
.env
.env.local
.env.production

# Backend (Python)
backend/venv/
backend/__pycache__/
backend/.pytest_cache/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.Python
backend/pip-log.txt
backend/pip-delete-this-directory.txt

# Frontend (Next.js)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/next-env.d.ts

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor & IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build outputs
dist/
build/

# Temporary files
tmp/
temp/
